    {
      "parameters": {
        "jsCode": "const aiResponse = $input.first().json.text;\n\nif (!aiResponse) {\n  throw new Error('No response from LLM Chain.');\n}\n\nlet emailData;\ntry {\n  const cleaned = aiResponse\n    .replace(/```json|```/g, '')\n    .replace(/^[^{]*/, '')\n    .replace(/[^}]*$/, '')\n    .trim();\n  emailData = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('AI did not return valid JSON. Raw: ' + aiResponse);\n}\n\nif (!emailData.to || !emailData.to.includes('@')) {\n  throw new Error('AI could not extract a valid email address.');\n}\n\nif (!emailData.body || emailData.body.length < 20) {\n  throw new Error('AI did not generate a proper email body.');\n}\n\nreturn [{\n  json: {\n    to: emailData.to.trim(),\n    subject: emailData.subject || 'Message from AI Assistant',\n    body: emailData.body\n  }\n}];"
      },
